[
  {
    "description": "Criar uma nova Task no Azure Boards",
    "method": "POST",
    "payload": [
      {
        "op": "add",
        "path": "/fields/System.Title",
        "value": "Implementar logs de auditoria"
      },
      {
        "op": "add",
        "path": "/fields/System.Description",
        "value": "Necessário registrar todas as alterações de permissão no banco de dados."
      },
      {
        "op": "add",
        "path": "/fields/System.AssignedTo",
        "value": "dev@exemplo.com"
      },
      {
        "op": "add",
        "path": "/fields/Microsoft.VSTS.Common.Priority",
        "value": 1
      }
    ]
  },
  {
    "description": "Mover Work Item para 'Active'",
    "method": "PATCH",
    "payload": [
      {
        "op": "replace",
        "path": "/fields/System.State",
        "value": "Active"
      }
    ]
  },
  {
    "description": "Adicionar Tags a um Work Item existente",
    "method": "PATCH",
    "payload": [
      {
        "op": "add",
        "path": "/fields/System.Tags",
        "value": "Refatoração; Débito Técnico"
      }
    ]
  },
  {
    "description": "Remover um revisor de um PR (Exemplo de lógica de remoção)",
    "method": "PATCH",
    "payload": [
      {
        "op": "remove",
        "path": "/reviewers/uuid-do-revisor"
      }
    ]
  },
  {
    "description": "Adicionar um Comentário a um Work Item",
    "method": "PATCH",
    "payload": [
      {
        "op": "add",
        "path": "/fields/System.History",
        "value": "Iniciando a implementação conforme discutido na daily."
      }
    ]
  }
]
