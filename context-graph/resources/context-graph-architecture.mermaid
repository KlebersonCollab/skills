graph TD
    subgraph "Agent Intelligence Layer"
        A[Context Graph] --> B(Episodic Memory)
        A --> C(Semantic Memory)
        A --> D(Procedural Memory)
    end

    subgraph "Data Storage"
        B --> B1[Decision Ledger: DECISIONS.md]
        C --> C1[Patterns: PATTERNS.md]
        C --> C2[Tribal Knowledge: KNOWLEDGE.md]
        D --> D1[Standard Procedures: SKILL.md]
    end

    subgraph "Execution Cycle"
        E[Task Initiation] --> F{Query Context Graph}
        F -->|Precedent Found| G[Apply Pattern]
        F -->|No Precedent| H[Analyze Alternatives]
        H --> I[Make Decision]
        I --> J[Record Trace]
        J --> B1
        G --> K[Execute Act]
        K --> L[Record Outcome]
        L --> B1
    end

    style A fill:#f9f,stroke:#333,stroke-width:4px
    style B1 fill:#fff,stroke:#333,stroke-dasharray: 5 5
    style C1 fill:#fff,stroke:#333,stroke-dasharray: 5 5
    style D1 fill:#fff,stroke:#333,stroke-dasharray: 5 5
