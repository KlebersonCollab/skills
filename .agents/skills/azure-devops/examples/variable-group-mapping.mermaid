graph TD
    subgraph Governance_Layer
        VG1[Variable Group: Shared-Infrastructure]
        VG2[Variable Group: KV-Secrets-Prod]
        AKV[(Azure Key Vault)]
    end

    subgraph Pipeline_Definitions
        P1[Order-Service-Pipeline]
        P2[Payment-Service-Pipeline]
    end

    AKV -- Linked To --> VG2
    
    VG1 -- Authorized For --> P1
    VG1 -- Authorized For --> P2
    VG2 -- Authorized For --> P2

    P1 -- Inherits --> V1[DB_HOST, PORT]
    P2 -- Inherits --> V1
    P2 -- Inherits --> V2[STRIPE_KEY, CERT]

    style AKV fill:#f96,stroke:#333,stroke-width:2px
    style VG2 fill:#bbf,stroke:#333,stroke-width:2px
